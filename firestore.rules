rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: media
    // Document ID: auto-generated
    // Fields:
    //   - url: string (required, valid URL)
    //   - type: string (required, 'image')
    //   - caption: string (required, max 40 chars)
    //   - likedBy: list (required, list of UIDs)
    //   - likesCount: number (required, >= 0)
    //   - rotation: number (required)
    //   - date: string (required)
    //   - tableNumber: string (required)
    //   - authorUid: string (required, must match creator's UID)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - cafeName: string
    //   - accentColor: string
    //   - handwritingFont: string
    //   - campaignTarget: number
    //   - campaignReward: string
    //
    // Collection: users
    // Document ID: UID
    // Fields:
    //   - role: string ('admin' or 'user')
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function hasPrivilegedEmail() {
      return isAuthenticated() &&
        request.auth.token.email_verified == true &&
        (
          request.auth.token.email == "fariddmahmudlu2008@gmail.com" ||
          request.auth.token.email == "aslankerem182@gmail.com"
        );
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          hasPrivilegedEmail()
        );
    }

    function isOwnerPortalAccount() {
      return hasPrivilegedEmail();
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    
    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }
    
    function isValidMediaItem(data) {
      return hasRequiredFields(['url', 'type', 'caption', 'likedBy', 'likesCount', 'rotation', 'date', 'tableNumber', 'cafeSlug', 'cafeName', 'authorUid', 'createdAt']) &&
             hasOnlyAllowedFields(['url', 'type', 'caption', 'likedBy', 'likesCount', 'rotation', 'date', 'tableNumber', 'cafeSlug', 'cafeName', 'authorUid', 'createdAt']) &&
             isValidUrl(data.url) &&
             data.type == 'image' &&
             data.caption is string && data.caption.size() <= 100 &&
             data.likedBy is list && data.likedBy.size() <= 10000 &&
             data.likesCount is number && data.likesCount >= 0 &&
             data.rotation is number &&
             data.date is string && data.date.size() <= 20 &&
             data.tableNumber is string && data.tableNumber.size() <= 40 &&
             data.cafeSlug is string && data.cafeSlug.size() <= 80 &&
             data.cafeName is string && data.cafeName.size() <= 120 &&
             data.authorUid is string && data.authorUid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidCafeSettings(data, cafeId) {
      return data.keys().hasAll(['cafeSlug', 'cafeName', 'accentColor', 'handwritingFont', 'campaignTarget', 'campaignReward', 'ownerEmail']) &&
             data.keys().hasOnly(['cafeSlug', 'cafeName', 'accentColor', 'handwritingFont', 'campaignTarget', 'campaignReward', 'ownerEmail']) &&
             data.cafeSlug is string && data.cafeSlug == cafeId && data.cafeSlug.size() <= 80 &&
             data.cafeName is string && data.cafeName.size() <= 120 &&
             data.accentColor is string && data.accentColor.matches("^#[0-9A-Fa-f]{6}$") &&
             data.handwritingFont is string && data.handwritingFont.size() <= 120 &&
             data.campaignTarget is number && data.campaignTarget >= 1 && data.campaignTarget <= 20 &&
             data.campaignReward is string && data.campaignReward.size() <= 120 &&
             data.ownerEmail is string && data.ownerEmail.size() <= 160;
    }

    function isLikeToggle() {
      let diff = request.resource.data.diff(resource.data);
      let affected = diff.affectedKeys();
      
      // Only likedBy and likesCount can change
      let onlyLikesChanged = affected.hasOnly(['likedBy', 'likesCount']);
      
      let wasLiked = request.auth.uid in resource.data.likedBy;
      let isLiked = request.auth.uid in request.resource.data.likedBy;
      
      let addedLike = !wasLiked && isLiked && 
                      request.resource.data.likesCount == resource.data.likesCount + 1 &&
                      request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1;
                      
      let removedLike = wasLiked && !isLiked && 
                        request.resource.data.likesCount == resource.data.likesCount - 1 &&
                        request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1;
                        
      return onlyLikesChanged && (addedLike || removedLike);
    }

    match /media/{mediaId} {
      // Gallery feed is visible to guests; write actions still require authentication
      allow read: if true;
      
      // Anyone authenticated can create if data is valid
      allow create: if isAuthenticated() && isValidMediaItem(request.resource.data);
      
      // Updates allowed for toggling likes
      allow update: if isAuthenticated() && isLikeToggle();
      
      // Only the owner or admin can delete
      allow delete: if isOwner() || isAdmin();
    }

    match /cafes/{cafeId} {
      allow read: if true;

      allow create: if
        isOwnerPortalAccount() &&
        isValidCafeSettings(request.resource.data, cafeId) &&
        request.resource.data.ownerEmail == request.auth.token.email;

      allow update: if
        isValidCafeSettings(request.resource.data, cafeId) &&
        (
          isAdmin() ||
          (
            isOwnerPortalAccount() &&
            resource.data.ownerEmail == request.auth.token.email &&
            request.resource.data.ownerEmail == resource.data.ownerEmail
          )
        );

      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
    }
  }
}
