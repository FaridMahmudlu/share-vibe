# ═══════════════════════════════════════════════════════════════════════════════
# SHARE VIBE - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control (should be in .gitignore)
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE CONFIGURATION
# Get these from Firebase Console → Project Settings
# ─────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_app_id

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
# Options: development | production | staging
VITE_ENV=development

# Local API URL (for development)
VITE_API_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# ERROR TRACKING (Optional - Sentry)
# Create account at https://sentry.io
# ─────────────────────────────────────────────────────────────────────────────
# VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────
# Enable error tracking (Sentry)
VITE_ENABLE_ERROR_TRACKING=false

# Enable analytics (Firebase Analytics)
VITE_ENABLE_ANALYTICS=false

# Enable debug mode (verbose logging)
VITE_DEBUG_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIG
# ─────────────────────────────────────────────────────────────────────────────
# Maximum upload file size (bytes)
VITE_MAX_UPLOAD_SIZE=8000000

# Maximum image dimensions
VITE_MAX_IMAGE_WIDTH=4096
VITE_MAX_IMAGE_HEIGHT=4096

# Maximum weekly uploads per user per café
VITE_MAX_WEEKLY_UPLOADS=2

# Media retention period (days)
VITE_MEDIA_RETENTION_DAYS=7

