{
  "entities": {
    "MediaItem": {
      "title": "MediaItem",
      "description": "A photo uploaded by a user from a specific table.",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL of the uploaded media in Firebase Storage"
        },
        "type": {
          "type": "string",
          "enum": ["image"],
          "description": "Type of the media"
        },
        "caption": {
          "type": "string",
          "description": "User-provided caption"
        },
        "likedBy": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of user UIDs who liked this media"
        },
        "likesCount": {
          "type": "number",
          "description": "Total number of likes"
        },
        "rotation": {
          "type": "number",
          "description": "Random rotation applied to the polaroid frame"
        },
        "date": {
          "type": "string",
          "description": "Formatted time string (e.g., '15:45')"
        },
        "tableNumber": {
          "type": "string",
          "description": "Table number string"
        },
        "authorUid": {
          "type": "string",
          "description": "UID of the user who uploaded the media"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        }
      },
      "required": ["url", "type", "caption", "likedBy", "likesCount", "rotation", "date", "tableNumber", "authorUid", "createdAt"]
    }
  },
  "firestore": {
    "/media/{mediaId}": {
      "schema": {
        "$ref": "#/entities/MediaItem"
      },
      "description": "Collection of all uploaded media items"
    }
  }
}
