  "shortcuts": [
    {
      "name": "Fotoğraf Paylaş",
      "short_name": "Paylaş",
      "description": "Kafe fotoğrafını hemen paylaş",
      "url": "/?action=upload",
      "icons": [
        {
          "src": "/shortcut-upload-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Galeriyi Aç",
      "short_name": "Galeri",
      "description": "Kafe galerilerine bak",
      "url": "/?action=gallery",
      "icons": [
        {
          "src": "/shortcut-gallery-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/webp", "image/gif"]
        }
      ]
    }
  },
  "prefer_related_applications": false,
  "related_applications": [],
  "launch_handler": {
    "client_mode": ["navigate-new", "auto"]
  },
  "screenshots_for_help": [
